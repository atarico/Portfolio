---
const icons = {
  email:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>`,
  github:   `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 6.609c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.562 21.8 24 17.302 24 12 24 5.373 18.627 0 12 0z"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0h.003z"/></svg>`,
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`,
};

interface ContactLink {
  label:   string;
  value:   string;
  href:    string;
  iconKey: keyof typeof icons;
}

const contactLinks: ContactLink[] = [
  {
    label:   'email',
    value:   'agustintarico9@gmail.com',
    href:    'mailto:agustintarico9@gmail.com',
    iconKey: 'email',
  },
  {
    label:   'github',
    value:   'github.com/atarico',
    href:    'https://github.com/atarico',
    iconKey: 'github',
  },
  {
    label:   'linkedin',
    value:   'linkedin.com/in/agustin-tarico',
    href:    'https://linkedin.com/in/agustin-tarico',
    iconKey: 'linkedin',
  },
  {
    label:   'whatsapp',
    value:   '+54 11 5664 3612',
    href:    'https://wa.me/541156643612',
    iconKey: 'whatsapp',
  },
];
---

<section id="contact" class="contact-section">
  <div class="contact-inner">

    <!-- ── Título terminal ── -->
    <header class="contact-header reveal">
      <p class="section-label">
        <span class="label-prefix">&gt;</span> ssh atarico@contacto
      </p>
      <p class="section-meta">
        <span class="meta-ok">Connection established.</span>
        <span class="meta-sep">//</span>
        <span>Ready to receive.</span>
      </p>
    </header>

    <!-- ── Layout dos columnas ── -->
    <div class="contact-grid">

      <!-- Columna izquierda: formulario -->
      <div class="reveal" style="transition-delay: 120ms">
        <div class="form-terminal">

          <!-- Titlebar -->
          <div class="terminal-titlebar">
            <span class="dot dot-red"    aria-hidden="true"></span>
            <span class="dot dot-yellow" aria-hidden="true"></span>
            <span class="dot dot-green"  aria-hidden="true"></span>
            <span class="terminal-title">send-message.sh</span>
          </div>

          <!-- Cuerpo del formulario -->
          <div class="terminal-body">

            <!-- Prompt del "comando" -->
            <p class="cmd-line">
              <span class="prompt">$</span>
              <span class="cmd-text">send-message --to atarico</span>
              <span class="cursor-blink cmd-cursor" aria-hidden="true"></span>
            </p>

            <form
              class="contact-form"
              novalidate
              id="contact-form"
            >
              <!-- Campo nombre -->
              <div class="field-group">
                <label for="name" class="field-label">
                  <span class="field-arrow">&gt;</span> nombre
                  <span class="field-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="field-input"
                  autocomplete="name"
                  required
                  spellcheck="false"
                />
              </div>

              <!-- Campo email -->
              <div class="field-group">
                <label for="email" class="field-label">
                  <span class="field-arrow">&gt;</span> email
                  <span class="field-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="field-input"
                  autocomplete="email"
                  required
                  spellcheck="false"
                />
              </div>

              <!-- Campo mensaje -->
              <div class="field-group">
                <label for="message" class="field-label">
                  <span class="field-arrow">&gt;</span> mensaje
                  <span class="field-required" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  class="field-input field-textarea"
                  rows="5"
                  required
                  spellcheck="false"
                ></textarea>
              </div>

              <!-- Submit -->
              <div class="form-footer">
                <button type="submit" class="btn-submit" id="submit-btn">
                  <span class="btn-prefix" aria-hidden="true">$</span>
                  <span class="btn-text">Enviar mensaje</span>
                </button>
                <p class="form-status" id="form-status" aria-live="polite"></p>
              </div>
            </form>

          </div>
        </div>
      </div>

      <!-- Columna derecha: info de contacto -->
      <div class="contact-info reveal" style="transition-delay: 280ms">

        <p class="info-intro">
          <span class="info-prompt">&gt;&nbsp;</span>
          ¿Preferís el contacto directo?
        </p>

        <ul class="info-links">
          {contactLinks.map((link, i) => (
            <li
              class="info-item"
              style={`animation-delay: ${400 + i * 100}ms`}
            >
              <a
                href={link.href}
                class="info-link"
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                <span class="info-prefix" aria-hidden="true">[<Fragment set:html={icons[link.iconKey]} />]</span>
                <span class="info-label">{link.label}</span>
                <span class="info-sep" aria-hidden="true">→</span>
                <span class="info-value">{link.value}</span>
              </a>
            </li>
          ))}
        </ul>

        <!-- Nota sobre tiempo de respuesta -->
        <p class="info-footer">
          <span class="info-comment">//</span>
          Respondo en menos de 24hs.
        </p>

      </div>
    </div>

  </div>
</section>

<script>
  /* ── Reveal con IntersectionObserver ── */
  const revealEls = document.querySelectorAll<HTMLElement>('#contact .reveal');

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  revealEls.forEach((el) => revealObserver.observe(el));

  /* ── Estado del formulario ── */
  const form       = document.getElementById('contact-form')   as HTMLFormElement | null;
  const statusEl   = document.getElementById('form-status')    as HTMLElement | null;
  const submitBtn  = document.getElementById('submit-btn')     as HTMLButtonElement | null;
  const btnText    = submitBtn?.querySelector<HTMLElement>('.btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !statusEl || !submitBtn || !btnText) return;

    // Estado: enviando
    submitBtn.disabled = true;
    btnText.textContent = 'Enviando...';
    statusEl.textContent = '';
    statusEl.className = 'form-status';

    try {
      const formData = new FormData(form);
      formData.append('access_key', 'e6f7bde7-414f-43cb-bc78-69fcff3e21e2');
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });

      const data = await res.json();

      if (res.ok && data.success) {
        statusEl.textContent = '✓ Mensaje enviado correctamente.';
        statusEl.classList.add('status-ok');
        form.reset();
        btnText.textContent = 'Enviar mensaje';
        submitBtn.disabled = false;
      } else {
        throw new Error(data.message ?? 'server-error');
      }
    } catch {
      statusEl.textContent = '✗ Error al enviar. Intentá de nuevo.';
      statusEl.classList.add('status-error');
      btnText.textContent = 'Enviar mensaje';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  /* ── Sección ── */
  .contact-section {
    padding: 4rem 1.5rem;
  }

  .contact-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── Header ── */
  .contact-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .section-label {
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .label-prefix {
    color: var(--text-accent);
    text-shadow: var(--glow-sm);
    font-weight: 700;
  }

  .section-meta {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: 0.06em;
  }

  .meta-ok  { color: var(--text-accent); opacity: 0.8; }
  .meta-sep { opacity: 0.3; }

  /* ── Grid ── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 0.85fr;
      align-items: start;
      gap: 3rem;
    }
  }

  /* ── Terminal del formulario ── */
  .form-terminal {
    border: 1px solid var(--border-accent);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--glow-sm), 0 12px 36px rgba(0, 0, 0, 0.45);
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1rem;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-accent);
    user-select: none;
  }

  .dot {
    display: block;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .terminal-body {
    padding: 1.1rem 1.25rem 1.4rem;
    background: rgba(10, 10, 10, 0.97);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  /* Línea del comando */
  .cmd-line {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
  }

  .prompt {
    color: var(--text-accent);
    text-shadow: var(--glow-sm);
    font-weight: 700;
  }

  .cmd-text {
    color: var(--text-primary);
    opacity: 0.75;
  }

  .cmd-cursor {
    display: inline-block;
    width: 0.5em;
    height: 0.85em;
    background: var(--text-accent);
    vertical-align: text-bottom;
    box-shadow: var(--glow-sm);
  }

  /* ── Formulario ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .field-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    cursor: text;
    user-select: none;
  }

  .field-arrow {
    color: var(--text-accent);
    opacity: 0.7;
    font-weight: 700;
  }

  .field-required {
    color: var(--text-accent);
    opacity: 0.5;
    font-size: 0.6rem;
  }

  .field-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.82rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow   0.2s ease,
      background   0.2s ease;
    caret-color: var(--text-accent);
  }

  .field-input::placeholder {
    color: transparent;
  }

  .field-input:focus {
    border-color: var(--text-accent);
    box-shadow: var(--glow-sm);
    background: rgba(0, 255, 65, 0.03);
  }

  .field-textarea {
    resize: vertical;
    min-height: 7rem;
    max-height: 7rem;
    line-height: 1.6;
  }

  /* ── Botón submit ── */
  .form-footer {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-accent);
    background: transparent;
    border: 1px solid var(--text-accent);
    border-radius: 3px;
    cursor: pointer;
    box-shadow: var(--glow-sm);
    transition:
      background 0.2s ease,
      color      0.2s ease,
      box-shadow 0.2s ease;
    align-self: flex-start;
  }

  .btn-submit:hover:not(:disabled) {
    background: var(--text-accent);
    color: var(--bg-primary);
    box-shadow: var(--glow-md);
  }

  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-prefix {
    color: inherit;
    opacity: 0.7;
    font-size: 0.85em;
  }

  /* Estado del formulario */
  .form-status {
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    min-height: 1rem;
  }

  .form-status.status-ok    { color: var(--text-accent); }
  .form-status.status-error { color: #ff5f57; }

  /* ── Info de contacto ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .info-intro {
    font-size: 0.82rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0;
  }

  .info-prompt {
    color: var(--text-accent);
    font-weight: 700;
    opacity: 0.7;
  }

  .info-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .info-item {
    opacity: 0;
    animation: slideIn 0.4s ease forwards;
  }

  /* Solo anima cuando el padre es visible */
  .reveal:not(.is-visible) .info-item {
    animation: none;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0);    }
  }

  .info-link {
    display: grid;
    grid-template-columns: 2.2rem 4.5rem auto 1fr;
    align-items: baseline;
    gap: 0 0.5rem;
    padding: 0.55rem 0.6rem;
    border-radius: 4px;
    transition: background 0.15s ease;
    text-decoration: none;
  }

  .info-link:hover {
    background: rgba(0, 255, 65, 0.05);
  }

  .info-prefix {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: var(--text-accent);
    opacity: 0.55;
  }

  .info-prefix svg {
    width: 0.6rem;
    height: 0.6rem;
    flex-shrink: 0;
    vertical-align: middle;
  }

  .info-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .info-sep {
    font-size: 0.76rem;
    color: var(--text-muted);
    opacity: 0.3;
  }

  .info-value {
    font-size: 0.9rem;
    color: var(--text-primary);
    transition: color 0.2s ease, text-shadow 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .info-link:hover .info-value {
    color: var(--text-accent);
    text-shadow: var(--glow-sm);
  }

  .info-footer {
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0.5;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .info-comment {
    color: var(--text-accent);
    opacity: 0.4;
  }

  /* ── Reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity   0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .info-link {
      grid-template-columns: 2rem 4rem auto 1fr;
    }

    .info-value {
      font-size: 0.7rem;
    }
  }
</style>
