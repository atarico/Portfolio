---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border-accent)] py-10 mt-20">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 font-mono text-xs text-muted">

    <!-- Copyright -->
    <p>
      <span class="text-accent opacity-50" style="font-size: 0.95rem">&copy;</span>{' '}
      {year} <span class="text-accent">Agustín Tarico</span>. Todos los derechos reservados.
    </p>

    <!-- Built with -->
    <p class="text-center md:text-right">
      <span class="text-accent opacity-50">//</span>{' '}
      Built with{' '}
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-glow transition-colors duration-200"
      >
        Astro
      </a>
    </p>

  </div>
</footer>
