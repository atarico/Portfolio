---
const links = [
  { href: '#hero',       label: 'Inicio'      },
  { href: '#about',      label: 'Sobre mí'    },
  { href: '#projects',   label: 'Proyectos'   },
  { href: '#experience', label: 'Experiencia' },
  { href: '#tech',       label: 'Skills'      },
  { href: '#contact',    label: 'Contacto'    },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav
    class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between"
    aria-label="Navegación principal"
  >
    <!-- Logo: prompt de terminal -->
    <a
      href="#hero"
      class="logo group flex items-center gap-0 font-mono text-base select-none"
      aria-label="Agustín Tarico — inicio"
    >
      <span class="text-muted" aria-hidden="true">~/</span>
      <span class="text-accent font-medium">atarico</span>
      <span class="text-muted ml-2" aria-hidden="true">$</span>
      <span class="cursor-blink ml-1 text-accent font-bold" aria-hidden="true">_</span>
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex items-center gap-7" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="nav-link text-muted hover:text-accent text-base tracking-widest uppercase transition-colors duration-200"
            aria-current="false"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger button (mobile) -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden flex flex-col justify-center gap-1.25 w-10 h-10 p-1.5 text-accent rounded"
    >
      <span class="hamburger-bar block w-full h-px bg-current origin-center transition-all duration-300"></span>
      <span class="hamburger-bar block w-full h-px bg-current transition-all duration-300"></span>
      <span class="hamburger-bar block w-full h-px bg-current origin-center transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="mobile-menu hidden md:hidden"
    role="navigation"
    aria-label="Menú de navegación móvil"
  >
    <ul class="flex flex-col py-4 px-6 gap-1" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="mobile-link block text-muted hover:text-accent text-sm tracking-widest uppercase transition-colors duration-200 py-3 border-b border-(--border-accent) last:border-0"
            aria-current="false"
          >
            <span class="text-accent opacity-60 mr-2 font-bold" aria-hidden="true">&gt;</span>{label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const navbar     = document.getElementById('navbar')!;
  const toggle     = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bars       = navbar.querySelectorAll<HTMLElement>('.hamburger-bar');

  /* ────────────────────────────────────────────────
   * Scroll: fondo semi-transparente al bajar
   * ──────────────────────────────────────────────── */
  const onScroll = () => {
    navbar.classList.toggle('navbar-scrolled', window.scrollY > 30);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ────────────────────────────────────────────────
   * Hamburger menu
   * ──────────────────────────────────────────────── */
  let open = false;

  const closeMenu = () => {
    if (!open) return;
    open = false;
    toggle.setAttribute('aria-expanded', 'false');
    mobileMenu.classList.add('hidden');
    bars[0]!.style.transform = '';
    bars[1]!.style.opacity   = '1';
    bars[2]!.style.transform = '';
  };

  const openMenu = () => {
    open = true;
    toggle.setAttribute('aria-expanded', 'true');
    mobileMenu.classList.remove('hidden');
    bars[0]!.style.transform = 'translateY(6px) rotate(45deg)';
    bars[1]!.style.opacity   = '0';
    bars[2]!.style.transform = 'translateY(-6px) rotate(-45deg)';
  };

  toggle.addEventListener('click', () => (open ? closeMenu() : openMenu()));

  // Cerrar al hacer click en un link del menú mobile
  mobileMenu.querySelectorAll('.mobile-link').forEach(link =>
    link.addEventListener('click', closeMenu)
  );

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) closeMenu();
  });

  /* ────────────────────────────────────────────────
   * Active section via IntersectionObserver
   * ──────────────────────────────────────────────── */
  const sections    = document.querySelectorAll<HTMLElement>('section[id]');
  const desktopLinks = navbar.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const mobileLinks  = mobileMenu.querySelectorAll<HTMLAnchorElement>('.mobile-link');
  const allNavLinks  = [...desktopLinks, ...mobileLinks];

  const setActive = (id: string) => {
    allNavLinks.forEach((link) => {
      const isActive = link.getAttribute('href') === `#${id}`;
      link.classList.toggle('nav-link--active', isActive);
      link.setAttribute('aria-current', isActive ? 'true' : 'false');
    });
  };

  // Altura del navbar fijo
  const NAVBAR_HEIGHT = navbar.offsetHeight;

  const getActiveSection = () => {
    let current = 'hero';
    sections.forEach((section) => {
      const top = section.getBoundingClientRect().top;
      if (top <= NAVBAR_HEIGHT + 16) {
        current = section.getAttribute('id') ?? current;
      }
    });
    return current;
  };

  // Iniciar con la sección correcta
  setActive(getActiveSection());

  window.addEventListener('scroll', () => setActive(getActiveSection()), { passive: true });
</script>

<style>
  #navbar {
    background: transparent;
  }

  #navbar.navbar-scrolled {
    background: rgba(10, 10, 10, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-accent);
    box-shadow: 0 4px 24px rgba(0, 255, 65, 0.04);
  }

  .mobile-menu {
    background: rgba(11, 11, 11, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-accent);
  }

  /* ── Desktop link: línea animada al hover ── */
  .nav-link {
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--text-accent);
    box-shadow: var(--glow-sm);
    transition: width 0.25s ease;
  }

  .nav-link:hover::after,
  .nav-link.nav-link--active::after {
    width: 100%;
  }

  /* ── Estado activo ── */
  .nav-link--active {
    color: var(--text-accent) !important;
    text-shadow: var(--glow-sm);
  }

  .mobile-link.nav-link--active {
    color: var(--text-accent) !important;
  }

  /* ── Focus visible para teclado ── */
  .nav-link:focus-visible,
  .mobile-link:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  #menu-toggle:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
