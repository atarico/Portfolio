      <a href="#contact"  class="btn-ghost">Contactame</a>
    </div>

    <!-- Social links -->
    <div class="hero-item hero-socials" style="animation-delay: 920ms">
      <a href="https://github.com/atarico" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
