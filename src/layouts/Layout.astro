---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = 'Agustín Tarico | Full Stack Developer',
  description = 'Full Stack Developer especializado en TypeScript, React y Node.js. Construyo productos digitales con foco en rendimiento, arquitectura limpia y buena experiencia de usuario.',
  ogImage     = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://atarico.dev');
const ogImageURL   = new URL(ogImage, Astro.site ?? 'https://atarico.dev');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="author"       content="Agustín Tarico" />
    <meta name="robots"       content="index, follow" />
    <link rel="canonical"     href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:locale"      content="es_AR" />
    <meta property="og:site_name"   content="Agustín Tarico" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />

    <!-- Google Fonts: JetBrains Mono — preconnect + preload + stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Skip to content (accesibilidad / teclado) -->
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <Navbar />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  /* ── Skip-to-content link ── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: var(--text-accent);
    color: var(--bg-primary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 0 0 4px 4px;
    text-decoration: none;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
    outline: 2px solid var(--bg-primary);
    outline-offset: 2px;
  }

  /* Asegurar que main recibe foco sin outline visible */
  #main-content:focus {
    outline: none;
  }
</style>
